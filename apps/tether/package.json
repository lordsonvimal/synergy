{
  "name": "tether",
  "version": "1.0.0",
  "description": "Remote terminal PWA — phone tethered to your Mac",
  "type": "module",
  "packageManager": "yarn@4.7.0",
  "scripts": {
    "dev": "concurrently \"yarn dev:server\" \"yarn dev:pwa\"",
    "dev:server": "tsx watch server/src/index.ts",
    "dev:pwa": "vite --port 5101",
    "build": "vite build && tsc --project server/tsconfig.json --noEmit",
    "serve": "node dist/server/index.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-cert": "bash scripts/generate-cert.sh"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "express": "^4.21.2",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.6",
    "node-pty": "^1.0.0",
    "solid-js": "^1.9.5",
    "strip-ansi": "^7.1.0",
    "ws": "^8.18.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.7",
    "@types/express": "^4.17.21",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.2",
    "eslint": "^9.17.0",
    "tailwindcss": "^4.1.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.2.1",
    "vite-plugin-solid": "^2.11.6",
    "vitest": "^3.0.4"
  }
}
